# Claude Code: ignore local tooling/state, but commit the shared project
# settings (settings.json) so cloud sessions pick up the MCP config on a fresh
# clone. Personal overrides (settings.local.json) stay ignored via *.local.
.claude/*
!.claude/settings.json

# OS junk
.DS_Store

# Temp image conversions
_shot*.png
_a.heic

# Cloudflare / Wrangler local secrets — NEVER commit (ADMIN_KEY etc.)
.dev.vars
.env
.env.*
.wrangler/
.mf/

# Dependencies / build output / logs
node_modules/
dist/
build/
*.log
npm-debug.log*
pnpm-debug.log*

# Playwright (R19 Tier A) — test artifacts, never shipped or committed
playwright-report/
test-results/
blob-report/
.playwright/

# Local-only overrides & caches
*.local
.cache/

# Editor
.vscode/
.idea/
