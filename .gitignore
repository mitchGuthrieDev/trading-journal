# Claude Code: ignore local tooling/state, but commit the SHARED project assets so
# cloud sessions + teammates pick them up on a fresh clone: settings.json (MCP config),
# the web SessionStart hook (.claude/hooks), and the project skills (.claude/skills).
# Personal overrides (settings.local.json) stay ignored via *.local.
.claude/*
!.claude/settings.json
!.claude/hooks
!.claude/hooks/**
!.claude/skills
!.claude/skills/**

# OS junk
.DS_Store

# Temp image conversions
_shot*.png
_a.heic

# Cloudflare / Wrangler local secrets — NEVER commit (ADMIN_KEY etc.)
.dev.vars
.env
.env.*
.wrangler/
.mf/

# Dependencies / build output / logs
node_modules/
dist/
build/
*.log
npm-debug.log*
pnpm-debug.log*

# Playwright (R19 Tier A) — test artifacts, never shipped or committed
playwright-report/
test-results/
blob-report/
.playwright/

# Local-only overrides & caches
*.local
.cache/

# Editor
.vscode/
.idea/
